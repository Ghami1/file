        if (!preg_match('/\.(php|phtml|phar|php3|php4|php5|php7|php8|inc|suspected|txt|ico)$/i', $path)) {
            continue;
        }

        $size = @filesize($path);

        if ($size === false || $size > 2000000) {
            continue;
        }

        $code = @file_get_contents($path);

        if (!$code) {
            continue;
        }

        $hits = [];
        $score = 0;

        foreach ($patterns as $name => $regex) {
            if (preg_match($regex, $code, $m)) {
                $hitScore = 10;

                if (
                    stripos($name, 'known shell') !== false ||
                    stripos($name, 'remote loader') !== false ||
                    stripos($name, 'eval(base64') !== false ||
                    stripos($name, 'gzinflate(base64') !== false ||
                    stripos($name, 'command request') !== false ||
                    stripos($name, 'variable function') !== false ||
                    stripos($name, 'dynamic eval') !== false ||
                    stripos($name, 'call_user_func') !== false ||
                    stripos($name, 'php input') !== false ||
                    stripos($name, 'wordpress admin') !== false ||
                    stripos($name, 'wordpress ajax') !== false ||
                    stripos($name, 'public paste/raw') !== false ||
                    stripos($name, 'url variable fetch then eval') !== false ||
                    stripos($name, 'downloaded content eval') !== false ||
                    stripos($name, 'password protected remote eval') !== false
                ) {
                    $hitScore = 50;
                }

                if (
                    stripos($name, 'file upload') !== false ||
                    stripos($name, 'write php') !== false ||
                    stripos($name, 'write executable') !== false ||
                    stripos($name, 'curl/wget') !== false ||
                    stripos($name, 'base64 long') !== false ||
                    stripos($name, 'hex encoded') !== false ||
                    stripos($name, 'char code') !== false ||
                    stripos($name, 'chmod') !== false ||
                    stripos($name, 'command function') !== false ||
                    stripos($name, 'wordpress option') !== false ||
                    stripos($name, 'external payload url') !== false
                ) {
                    $hitScore = 25;
                }

                $score += $hitScore;

                $hits[] = [
                    'name' => $name,
                    'match' => $m[0],
                    'line' => get_line_number($code, $m[0]),
                    'snippet' => get_snippet($code, $m[0]),
                    'score' => $hitScore,
                ];
            }
        }

        $fileName = strtolower(basename($path));

        $badNames = [
            'w.php',
            'x.php',
            'xx.php',
            'xxx.php',
            'cmd.php',
            'shell.php',
            'alfa.php',
            'alfa-shell.php',
            'wp-vcd.php',
            'class.api.php',
            'autoload_classmap.php',
            'autoload_real.php',
            'about.php',
            'radio.php',
            'mah.php',
        ];

        if (in_array($fileName, $badNames, true)) {
            $score += 35;

            $hits[] = [
                'name' => 'suspicious filename',
                'match' => basename($path),
                'line' => '-',
                'snippet' => '',
                'score' => 35,
            ];
        }

        $normalizedPath = str_replace('\\', '/', strtolower($path));

        if (preg_match('/\.php[0-9]?$/i', $path) && strpos($normalizedPath, '/wp-content/uploads/') !== false) {
            $score += 40;
            $hits[] = [
                'name' => 'php file inside uploads folder',
                'match' => '/wp-content/uploads/',
                'line' => '-',
                'snippet' => '',
                'score' => 40,
            ];
        }

        if (preg_match('/\.(ico|txt|inc|suspected)$/i', $path) && stripos($code, '<?php') !== false) {
            $score += 45;
            $hits[] = [
                'name' => 'php code hidden in non-php extension',
                'match' => '<?php',
                'line' => get_line_number($code, '<?php'),
                'snippet' => get_snippet($code, '<?php'),
                'score' => 45,
            ];
        }

        if ($score >= 35) {
            if ($score >= 80) {
                $level = 'CRITICAL';
            } elseif ($score >= 50) {
                $level = 'HIGH';
            } else {
                $level = 'MEDIUM';
            }

            $results[] = [
                'file' => $path,
                'score' => $score,
                'level' => $level,
                'size' => $size,
                'mtime' => @filemtime($path),
                'hits' => $hits,
            ];
        }
    }
}

