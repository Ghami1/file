function should_skip_folder($path) {
    $skip = [
        '/cache/',
        '/wp-content/cache/',
        '/node_modules/',
        '/.git/',
        '/vendor/bin/',
        '/quarantine_shells/',
        '/wp-content/uploads/cache/',
        '/wp-content/ai1wm-backups/',
        '/wp-content/updraft/',
        '/wp-content/backup/',
        '/wp-content/backups/',
    ];

    $p = str_replace('\\', '/', $path);

    foreach ($skip as $s) {
        if (stripos($p, $s) !== false) {
            return true;
        }
    }

    return false;
}

function get_snippet($code, $match) {
    $pos = stripos($code, $match);

    if ($pos === false) {
        $pos = 0;
    }

    return substr($code, max(0, $pos - 120), 800);
}

function get_line_number($code, $match) {
    $pos = stripos($code, $match);

    if ($pos === false) {
        return '-';
    }

    return substr_count(substr($code, 0, $pos), "\n") + 1;
}


function is_searchable_file($path) {
    $name = basename($path);

    if ($name === '.htaccess' || $name === 'htaccess') {
        return true;
    }

    return (bool)preg_match('/\.(php|phtml|phar|php3|php4|php5|php7|php8|inc|suspected|txt|ico|js|css|html|htm|xml|json|env|ini)$/i', $path);
}

function search_text_in_dir($dir, $needle, &$searchResults) {
    global $scannerSelf;

    if ($needle === '' || should_skip_folder($dir)) {
        return;
    }

    $items = @scandir($dir);
    if (!$items) {
        return;
    }

    foreach ($items as $item) {
        if ($item === '.' || $item === '..') {
            continue;
        }

        $path = $dir . DIRECTORY_SEPARATOR . $item;

        if (is_link($path)) {
            continue;
        }

        $realPath = realpath($path);
        if ($scannerSelf && $realPath && $realPath === $scannerSelf) {
            continue;
        }

        if (is_dir($path)) {
            search_text_in_dir($path, $needle, $searchResults);
            continue;
        }

        if (!is_searchable_file($path)) {
            continue;
        }

        $size = @filesize($path);
        if ($size === false || $size > 3000000) {
            continue;
        }

        $code = @file_get_contents($path);
        if ($code === false || $code === '') {
            continue;
        }

        $pos = stripos($code, $needle);
        if ($pos === false) {
            continue;
        }

        $hits = [];
        $offset = 0;
        $maxHitsPerFile = 5;

        while (($hitPos = stripos($code, $needle, $offset)) !== false && count($hits) < $maxHitsPerFile) {
            $line = substr_count(substr($code, 0, $hitPos), "\n") + 1;
            $snippet = substr($code, max(0, $hitPos - 160), 520);
            $hits[] = [
                'line' => $line,
                'snippet' => $snippet,
            ];
            $offset = $hitPos + max(1, strlen($needle));
        }

        $searchResults[] = [
            'file' => $path,
            'size' => $size,
            'mtime' => @filemtime($path),
            'hits' => $hits,
        ];

        if (count($searchResults) >= 300) {
            return;
        }
    }
}

function scan_dir_shell($dir, $patterns, &$results) {
